# Entorno local seguro (NO usar credenciales de produccion)
SECRET_KEY=dev-only-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos local Docker
POSTGRES_DB=dentalink_local
POSTGRES_USER=dentalink_user
POSTGRES_PASSWORD=dentalink_pass
DATABASE_URL=postgres://dentalink_user:dentalink_pass@db:5432/dentalink_local

# SMTP local con MailHog (UI: http://localhost:8025)
FRONTEND_BASE_URL=http://localhost:3000
DEFAULT_FROM_EMAIL=noreply@dentalinklab.local
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# Storage remoto opcional para media (S3/MinIO compatible)
USE_S3_MEDIA=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
