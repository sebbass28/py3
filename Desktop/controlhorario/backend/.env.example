# ===========================================================
# CONFIGURACIÓN DE ENTORNO - Control Horario Empleados
# ===========================================================

# ===========================================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================================
PORT=3000
NODE_ENV=development

# ===========================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_password
# Para el esquema MEJORADO usar: control_horario_empleados
# Para el esquema ANTIGUO usar: controlhorario_basico
DB_NAME=control_horario_empleados

# ===========================================================
# CONFIGURACIÓN DE SEGURIDAD
# ===========================================================
# IMPORTANTE: Cambia este secreto en producción
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_super_seguro_cambialo_en_produccion
JWT_EXPIRATION=24h

# ===========================================================
# CONFIGURACIÓN DE CORS (Frontend)
# ===========================================================
FRONTEND_URL=http://localhost:5500
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
